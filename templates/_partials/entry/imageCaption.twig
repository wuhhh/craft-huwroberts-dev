{% set block = entry.imageCaption ?? null %}
{% set image = block ? block.imageAsset.one() : null %}

{% if image %}
  {% set transform = { format: 'webp', mode: 'crop', width: 960, height: 576, quality: 90 } %}
  {% set caption = block.text ?? null %}

  <div class="space-y-4 {{ not entry.fullWidth ? 'lg:max-w-[calc(100%-371px)]' }}">
    <div class="group relative aspect-960/576 w-full">
      <img
        src="{{ image.getUrl(transform) }}"
        srcset="{{ image.getSrcset(['1x', '2x', '3x'], transform) }}"
        sizes="(max-width: 768px) 100vw, 960px"
        alt="{{ image.alt ?? '' }}"
        title="{{ image.title }}"
        class="h-full w-full rounded-lg object-cover"
        loading="lazy"
        decoding="async"
      />
    </div>
    {% if caption|length %}
      <p class="text-sm text-[#705959] italic">{{ caption }}</p>
    {% endif %}
  </div>
{% endif %}
