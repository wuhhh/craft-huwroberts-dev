{% extends "_layouts/scene" %}

{% block content %}

  {% set shortBio = entry.richTextSimple ?? null %}
  {% set tech = entry.tech ?? null %}
  {% set frequentItems = collect(tech).pluck("frequent") %}
  {% set occasionalItems = collect(tech).pluck("occasional") %}

  <div class="col-span-full relative min-h-screen w-full">

    <about-scene
      refImageId="scene-image-ref"
      class="sm-down:w-screen sm-down:-ml-6"
    ></about-scene>

    <div class="pt-33 sm:px-4 sm:pt-30 lg:px-0">
      <div class="relative md:grid grid-cols-12 gap-x-10">
        <div class="col-span-full lg:col-span-10 lg:col-start-2">
          {% include "_includes/breadcrumb" with {
            classes: "mb-8 sm:mb-12 md:mb-28",
            links: [
              {
                label: "Home",
                url: siteUrl,
              },
              {
                label: entry.title,
                url: "",
              }
            ]
          } only %}
        </div>
        <div class="col-span-10 lg:col-start-3 lg:col-span-7 xl:col-span-6 xl:col-start-5">
          <h1 class="sr-only">{entry.title}</h1>

          <div class="space-y-12" data-cursor-layer="top">
            <div id="scene-image-ref" class="relative overflow-hidden w-full aspect-9/8 md:aspect-70/58"></div>

            {% if shortBio %}
              <div class="rich-text -simple prose text-sm w-full max-w-162 px-8 pt-10 sm:pt-6 md:px-0 md:pt-0 md:text-base 2xl:text-lg 3xl:text-xl">
                {{ shortBio }}
              </div>
            {% endif %}
          </div>

          <div class="pointer-events-none md:absolute inset-0 translate-y-9.5 font-mono text-xs leading-3.5 uppercase px-8 pt-10 md:px-0 md:pt-0">
            <div class="relative md:grid grid-cols-12 gap-x-10">
              <div class="col-start-9 xl:col-start-10">
                <div class="flex gap-x-4 lg:gap-x-10">
                  {% if frequentItems|length %}
                    <div class="min-w-21">
                      <h2>Frequent</h2>
                      <div aria-hidden="true">++++++++</div>
                      <br />
                      <ul>
                        {% for frequentItem in frequentItems %}
                          <li>{{ frequentItem }}</li>
                        {% endfor %}
                      </ul>
                    </div>
                  {% endif %}

                  {% if occasionalItems|length %}
                    <div class="min-w-21">
                      <h2>Occasional</h2>
                      <div aria-hidden="true">++++++++++</div>
                      <br />
                      <ul>
                        {% for occasionalItem in occasionalItems %}
                          <li>{{ occasionalItem }}</li>
                        {% endfor %}
                      </ul>
                    </div>
                  {% endif %}
                </div>
              </div>

            </div>
          </div>
        </div>
      </div>

      {# three scene here #}
      {# ... #}

    </div>
  </div>

{% endblock %}
