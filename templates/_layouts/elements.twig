{% extends "_layouts/base" %}

{% set gridLinesVariant = gridLinesVariant ?? "full" %}

{% block base %}

  <div id="top"></div>

  {% include "_includes/followers/followerDot.twig" only %}

  <div class="container flex lg:gap-x-10">

    {% include "_includes/obi" only %}

    <div class="relative h-screen grow overflow-x-clip">

      <scene-canvas class="sm-down:w-screen sm-down:-ml-3"></scene-canvas>

      <div class="absolute top-0 w-full grid grid-cols-12 lg:gap-x-10">
        {% block content %}{% endblock %}
        {% include "_includes/footer" only %}
        {% include "_includes/decor/gridDecor.twig" with { variant: gridLinesVariant } only %}
      </div>

    </div>

  </div>

  {% include "_includes/followers/followerMore.twig" only %}

  {# == Lenis quick test == #}
  <link rel="stylesheet" href="https://unpkg.com/lenis@1.3.23/dist/lenis.css">
  <script src="https://unpkg.com/lenis@1.3.23/dist/lenis.min.js"></script>
  <script>new Lenis({ autoRaf: true, autoToggle: true, anchors: true, allowNestedScroll: true, naiveDimensions: true, stopInertiaOnNavigate: true })</script>

{% endblock %}
