{% extends "_layouts/base" %}

{% block base %}

  <div id="top"></div>

  {# {% include "_includes/followers/followerDot" only %} #}
  {# {% include "_includes/followers/followerHex" only %} #}

  <mouse-follower speed="10">
    <span class="block size-3 rounded-full bg-coral-red"></span>
  </mouse-follower>

  <star-flower class="container relative">
    {{ svg('@webroot/dist/images/icon--starflower.svg', true, true)|attr({ class: 'w-[30px]' }) }}
  </star-flower>

  <div class="container flex flex-col gap-x-17 sm:flex-row">

    {# Obi #}
    {% include "_includes/obi" only %}

    {# Grid #}
    <div class="relative h-screen grow grid grid-cols-12 lg:gap-x-10">

      <scene-canvas></scene-canvas>

      <div id="content">
        {% include "_includes/decor/gridDecor.twig" only %}
        {% block content %}{% endblock %}
      </div>

    </div>

  </div>

  {% include "_includes/followers/followerMore" only %}
  {% include "_includes/slideoverGql" only %}

  <style>
    html, body {
      {# == needed as quick hack to fix safari bug on the translated canvas == #}
      overscroll-behavior: none;
    }

    #content {
      position: absolute;
      top: 0; width: 100%;
    }

    .list-item {
      display: inline-block;
      margin: 1em;
      padding: 1em;
    }

    .list-item > div:nth-child(1) {
      width: 200px;
      height: 200px;
    }

    .list-item > div:nth-child(2) {
      color: #888;
      font-family: sans-serif;
      font-size: large;
      width: 200px;
      margin-top: 0.5em;
    }
  </style>

  {# == Lenis quick test == #}
  <link rel="stylesheet" href="https://unpkg.com/lenis@1.3.23/dist/lenis.css">
  <script src="https://unpkg.com/lenis@1.3.23/dist/lenis.min.js"></script>
  <script>new Lenis({ autoRaf: true, autoToggle: true, anchors: true, allowNestedScroll: true, naiveDimensions: true, stopInertiaOnNavigate: true })</script>

{% endblock %}
