{% import _self as macros %}

{% extends "_layouts/elements" %}

{% macro adjacentNavLink(entry, label, ariaAction, revealClip) %}

  {% set ease = 'ease-[cubic-bezier(0.785_0.135_0.15_0.86)]' %}
  {% set clipTransition = 'transition-[clip-path] duration-200 pointer-events-none' %}
  {% set hideClip = (revealClip == '[clip-path:inset(0_100%_0_0)]') ? '[clip-path:inset(0_0_0_100%)]' : '[clip-path:inset(0_100%_0_0)]' %}

  <div class="relative group">
    <span
      aria-hidden="true"
      class="absolute inset-0 bg-zinc-900 {{ revealClip }} {{ ease }} {{ clipTransition }} delay-0 group-hover:[clip-path:inset(0_0%_0_0)] group-hover:delay-200"
    ></span>
    <span
      aria-hidden="true"
      class="absolute inset-0 inline-flex items-center gap-x-4 text-white {{ revealClip }} {{ ease }} {{ clipTransition }} delay-0 group-hover:[clip-path:inset(0_0%_0_0)] group-hover:delay-200"
    >
      <em>{{ label }}:</em> {{ entry.title }}
    </span>
    <span
      aria-hidden="true"
      class="relative inline-flex items-center gap-x-4 [clip-path:inset(0_0%_0_0)] {{ ease }} {{ clipTransition }} delay-200 group-hover:{{ hideClip }} group-hover:delay-0"
    >
      <em>{{ label }}:</em> {{ entry.title }}
    </span>
    <a class="absolute inset-0" aria-label="View {{ ariaAction }} project: {{ entry.title }}" href="{{ url(entry.uri) }}"></a>
  </div>

{% endmacro %}

{% set gridLinesVariant = "outer" %}

{% block content %}

  {% set featureVideo = entry.featureVideo ?? null %}
  {% set featureImage = entry.imageCaption ?? null %}
  {% set summary = entry.summaryShort ?? null %}
  {% set liveUrl = entry.liveUrl ?? null %}
  {% set richTextPost = entry.richTextPost ?? null %}

  <div class="col-span-full grid grid-cols-subgrid">
    <div class="col-span-full pt-20 sm:px-4 sm:pt-30 lg:px-0 2xl:pt-36 lg:col-start-2 lg:col-span-10 2xl:col-start-2 2xl:col-span-9">

      {% include "_includes/breadcrumb" with {
        classes: "mb-8 sm:mb-12 2xl:mb-28",
        links: [
          {
            label: "Home",
            url: siteUrl,
          },
          {
            label: "Case Studies",
            url: "/work",
          },
          {
            label: entry.title,
            url: "",
          }
        ]
      } only %}

      <div class="flex items-center justify-between flex-wrap gap-x-8 gap-y-4 mb-10 2xl:mb-16">
        <h1 class="heading1 font-medium">{{ entry.title }}</h1>

        {% if liveUrl %}
          {% include "_includes/liveLink.twig" with {
            url: liveUrl,
          } only %}
        {% endif %}
      </div>

      <div class="space-y-12 2xl:space-y-18">

        {% if featureVideo and featureVideo.videoCaption and featureVideo.videoCaption.videoAsset.one() %}

          {% set caption = featureVideo.videoCaption.text ?? null %}

          <div class="space-y-4">
            {% include "_includes/featureVideo.twig" with {
              featureVideo: featureVideo,
              title: entry.title,
            } only %}

            {% if caption %}
              <div class="text-sm text-zinc-500 italic">{{ caption }}</div>
            {% endif %}
          </div>

        {% elseif featureImage and featureImage.imageAsset.one() %}

          {% set caption = featureImage.text ?? null %}

          <div class="space-y-4">
            {% include "_includes/featureImage.twig" with {
              featureImage: featureImage,
              title: entry.title,
            } only %}

            {% if caption %}
              <div class="text-sm text-zinc-500 italic">{{ caption }}</div>
            {% endif %}
          </div>

        {% endif %}

        {% if richTextPost %}
          {% include "_includes/richTextPost" with { content: richTextPost } only %}
        {% endif %}

      </div>

    </div>

    {% set params = craft.entries().section('work') %}
    {% set prev = entry.getPrev(params) ?? null %}
    {% set next = entry.getNext(params) ?? null %}

    {% if prev or next %}
      <div
        class="col-span-full pt-20 sm:px-4 sm:pt-30 lg:px-0 2xl:pt-36 lg:col-start-2 lg:col-span-10 2xl:col-start-2 2xl:col-span-9"
        aria-label="Navigate to adjacent entries"
      >
        <div class="flex items-center gap-x-6 py-3 text-zinc-900 font-mono text-sm">

          {% if prev %}
            {{ macros.adjacentNavLink(prev, 'Prev', 'previous', '[clip-path:inset(0_100%_0_0)]') }}
          {% endif %}

          <div class="w-16 h-px bg-zinc-900"></div>

          {% if next %}
            {{ macros.adjacentNavLink(next, 'Next', 'next', '[clip-path:inset(0_0_0_100%)]') }}
          {% endif %}

        </div>
      </div>
    {% endif %}

  </div>

{% endblock %}
