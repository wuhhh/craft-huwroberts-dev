{% set techTags = techTags ?? [] %}
{% set id = id ?? "tech-tags" %}

{% if techTags|length %}
  <div class="flex w-full overflow-x-scroll no-scrollbar fade-end gap-x-4 gap-y-2 xs-mono text-zinc-500">
    <h3 id="{{ id }}-label" class="flex items-center shrink-0 gap-x-0.5">
      {{ svg("@webroot/dist/images/icon--hash.svg", true, true)|attr({ class: "shrink-0" }) }} <span class="shrink-0">Tags:</span>
    </h3>
    <ul aria-labelledby="{{ id }}-label" class="flex gap-x-4 gap-y-2 list-none p-0 m-0">
      {% for techTag in techTags %}
      <li class="shrink-0 inline-block">{{ techTag }}</li>
      {% endfor %}
    </ul>
  </div>
{% endif %}
