{% set breadcrumbLinks = breadcrumbLinks ?? [] %}
{% set liveUrl = liveUrl ?? null %}

{% include "_includes/decor/decorCellGrid.twig" only %}

{% set featureVideo = entry.featureVideo ?? null %}
{% set featureImage = entry.imageCaption ?? null %}
{% set summary = entry.summaryShort ?? null %}
{% set richTextPost = entry.richTextPost ?? null %}
{% set techTags = entry.techTags.all() ?? [] %}

<div class="col-span-full grid grid-cols-subgrid">
  <div class="col-span-full pt-33 sm:pt-30 sm:px-4 lg:px-0 lg:col-start-2 lg:col-span-10 2xl:col-start-2 2xl:col-span-9">

    {% include "_includes/breadcrumb" with {
      classes: "mb-8 sm:mb-12 2xl:mb-20",
      links: breadcrumbLinks,
    } only %}

    {# post #}
    <div class="space-y-5 sm:space-y-8">

      {# title and live link #}
      <div class="flex items-end justify-between flex-wrap gap-x-8 gap-y-4">
        <h1 class="leading-none! heading2 sm:heading1 font-medium max-w-3xl">{{ entry.title }}</h1>
        {% if liveUrl %}
          {% include "_includes/liveLink.twig" with {
            url: liveUrl,
          } only %}
        {% endif %}
      </div>

      {# post head #}
      {% if summary %}
        <div class="rich-text -simple font-normal xl:max-w-[calc(100%-371px)]">
          {{ summary }}

          <div class="-mb-2"></div>
        </div>
      {% endif %}

      {# tags #}
      {% if techTags %}
        <div class="flex overflow-x-scroll no-scrollbar fade-end gap-x-4 gap-y-2 xs-mono text-zinc-500">
          <h3 id="tech-tags-label" class="flex items-center shrink-0 gap-x-0.5">
            {{ svg("@webroot/dist/images/icon--hash.svg", true, true)|attr({ class: "shrink-0" }) }} <span class="shrink-0">Tags:</span>
          </h3>
          <ul aria-labelledby="tech-tags-label" class="flex gap-x-4 gap-y-2 list-none p-0 m-0">
            {% for techTag in techTags %}
            <li class="shrink-0 inline-block">{{ techTag }}</li>
            {% endfor %}
          </ul>
        </div>
      {% endif %}

      {# feature video / image #}
      <div class="space-y-32">
        {% if featureVideo and featureVideo.videoCaption and featureVideo.videoCaption.videoAsset.one() %}

          {% set caption = featureVideo.videoCaption.text ?? null %}

          <div class="space-y-3">
            {% include "_includes/featureVideo.twig" with {
              featureVideo: featureVideo,
              title: entry.title,
            } only %}

            {% if caption %}
              <div class="text-xs ml-1 xl:text-sm text-zinc-500">{{ caption }}</div>
            {% endif %}
          </div>

        {% elseif featureImage and featureImage.imageAsset.one() %}

          {% set caption = featureImage.text ?? null %}

          <div class="space-y-3">
            {% include "_includes/featureImage.twig" with {
              featureImage: featureImage,
              title: entry.title,
            } only %}

            {% if caption %}
              <div class="text-xs ml-1 xl:text-sm text-zinc-500">{{ caption }}</div>
            {% endif %}
          </div>

        {% endif %}

      </div>

      {# post content #}
      {% if richTextPost %}
        {% include "_includes/richTextPost" with { content: richTextPost } only %}
      {% endif %}

    </div>

  </div>

  {% set params = craft.entries().section('work') %}
  {% set prev = entry.getPrev(params) ?? null %}
  {% set next = entry.getNext(params) ?? null %}

  {% if prev or next %}
    <div
      class="col-span-full pt-20 sm:px-4 sm:pt-30 lg:px-0 2xl:pt-36 lg:col-start-2 lg:col-span-10 2xl:col-start-2 2xl:col-span-9"
      aria-label="Navigate to adjacent entries"
    >
      <div class="flex flex-col-reverse items-start w-[clamp(14.6875rem,18.75rem,72.5%)] mx-auto gap-x-6 gap-y-2 py-3 font-mono text-sm md:w-auto md:mx-0 md:flex-row md:items-center">

        {% if prev %}
          <div class="relative group">
            <span aria-hidden="true" class="absolute inset-0 bg-zinc-900 [clip-path:inset(0_100%_0_0)] ease-[cubic-bezier(0.785_0.135_0.15_0.86)] transition-[clip-path] duration-200 delay-0 group-hover:[clip-path:inset(0_0%_0_0)] group-hover:delay-200 pointer-events-none"></span>
            <span
              aria-hidden="true"
              class="absolute inset-0 inline-flex items-center gap-x-3 text-white [clip-path:inset(0_100%_0_0)] ease-[cubic-bezier(0.785_0.135_0.15_0.86)] transition-[clip-path] duration-200 delay-0 group-hover:[clip-path:inset(0_0%_0_0)] group-hover:delay-200 pointer-events-none"
            >
              {{ svg("@webroot/dist/images/icon--arrow-left.svg", true, true)|attr({ class: "w-2.5 translate-y-px" }) }} <em>Prev:</em> {{ prev.title }}
            </span>
            <span
              aria-hidden="true"
              class="relative inline-flex items-center gap-x-3 [clip-path:inset(0_0_0_0%)] ease-[cubic-bezier(0.785_0.135_0.15_0.86)] transition-[clip-path] duration-200 delay-200 group-hover:[clip-path:inset(0_0_0_100%)] group-hover:delay-0"
            >
              {{ svg("@webroot/dist/images/icon--arrow-left.svg", true, true)|attr({ class: "w-2.5 translate-y-px" }) }} <em>Prev:</em> {{ prev.title }}
            </span>
            <a class="absolute inset-0" aria-label="View previous project: {{ prev.title }}" href="{{ url(prev.uri) }}"></a>

          </div>
        {% endif %}

        <div class="hidden md:block w-16 h-px bg-zinc-900"></div>

        {% if next %}
          <div class="relative group ml-auto md:ml-0">
            <span aria-hidden="true" class="absolute inset-0 bg-zinc-900 [clip-path:inset(0_0_0_100%)] ease-[cubic-bezier(0.785_0.135_0.15_0.86)] transition-[clip-path] duration-200 delay-0 group-hover:[clip-path:inset(0_0_0_0%)] group-hover:delay-200 pointer-events-none"></span>
            <span
              aria-hidden="true"
              class="absolute inset-0 inline-flex items-center gap-x-3 text-white [clip-path:inset(0_0_0_100%)] ease-[cubic-bezier(0.785_0.135_0.15_0.86)] transition-[clip-path] duration-200 delay-0 group-hover:[clip-path:inset(0_0_0_0%)] group-hover:delay-200 pointer-events-none"
            >
              <em>Next:</em> {{ next.title }} {{ svg("@webroot/dist/images/icon--arrow-left.svg", true, true)|attr({ class: "rotate-180 w-2.5 translate-y-px" }) }}
            </span>
            <span
              aria-hidden="true"
              class="relative inline-flex items-center gap-x-3 [clip-path:inset(0_0%_0_0)] ease-[cubic-bezier(0.785_0.135_0.15_0.86)] transition-[clip-path] duration-200 delay-200 group-hover:[clip-path:inset(0_100%_0_0)] group-hover:delay-0"
            >
              <em>Next:</em> {{ next.title }} {{ svg("@webroot/dist/images/icon--arrow-left.svg", true, true)|attr({ class: "rotate-180 w-2.5 translate-y-px" }) }}
            </span>
            <a class="absolute inset-0" aria-label="View next project: {{ next.title }}" href="{{ url(next.uri) }}"></a>

          </div>
        {% endif %}

      </div>
    </div>
  {% endif %}

</div>
