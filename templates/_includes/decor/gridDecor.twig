{# Render visible grid lines, variants are `full` | `double` | `outer` #}

{% set variant = variant ?? "full" %}

<div class="hidden pointer-events-none absolute inset-0 -z-10 sm:grid grid-cols-12 gap-x-10">

  {% if variant == "full" %}

    <!-- full -->
    <div class="col-span-full lg:col-span-6 xl:col-span-4 border-x border-[#f0edea]"></div>
    <div class="hidden lg:block lg:col-span-6 xl:col-span-4 border-x border-[#f0edea]"></div>
    <div class="hidden xl:block xl:col-span-4 border-x border-[#f0edea]"></div>

  {% elseif variant == "double" %}

    <!-- double -->
    <div class="col-span-full lg:col-span-6 border-x border-[#f0edea]"></div>
    <div class="hidden lg:block lg:col-span-6 border-x border-[#f0edea]"></div>

  {% elseif variant == "outer" %}

    <!-- outer -->
    <div class="col-span-full border-x border-[#f0edea]"></div>

  {% endif %}

</div>
