{% import _self as macros %}

{% macro gridCell(spacer = false, enclosed = false) %}
  <div class="{{ enclosed ? "size-[calc(var(--cell-size)+1px)]" : "size-(--cell-size)" }} {{ spacer ? "" : "border-b border-l" }} {{ enclosed ? "border-t border-r" : "" }} border-[#F0EDEA]"></div>
{% endmacro %}

{% macro gridCells(n, spacer = false) %}
  {% for i in 1..n %}
    {{ macros.gridCell(spacer) }}
  {% endfor %}
{% endmacro %}

