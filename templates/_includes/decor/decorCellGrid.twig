  {# always the same, just need --cell-top/left on the same el #}
  {% set tl = "top-[calc((var(--cell-top))*(var(--cell-size)))] left-[calc((var(--cell-left))*(var(--cell-size)))]" %}

  {# non contiguous cells #}
  <div class="absolute [--cell-top:3] [--cell-left:5] sm:[--cell-left:8] xl:[--cell-left:9] 2xl:[--cell-top:5] 2xl:[--cell-left:18] {{ tl }} -translate-y-px">
    {{ macros.gridCell(false, true) }}
  </div>
  <div class="hidden absolute [--cell-top:10] [--cell-left:32] {{ tl }} 2xl:block -translate-y-px">
    {{ macros.gridCell(false, true) }}
  </div>

  {# shapes #}
  <decor-diamond class="absolute [--cell-top:1] [--cell-left:7] lg:[--cell-left:10] xl:[--cell-top:2] xl:[--cell-left:16] 2xl:[--cell-left:18] {{ tl }} size-3 -translate-x-1/2 -translate-y-1/2 xl:size-5 2xl:size-6" color="coral"></decor-diamond>
  <decor-diamond class="absolute [--cell-top:2.5] [--cell-left:11.5] lg:[--cell-left:16.5] lg:[--cell-top:2.5] xl:[--cell-top:4.5] xl:[--cell-left:23.5] 2xl:[--cell-top:6.5] 2xl:[--cell-left:35.5] {{ tl }} size-3 2xl:size-4 -translate-x-1/2 -translate-y-1/2" color="indigo"></decor-diamond>
  <decor-diamond class="hidden absolute [--cell-top:2.5] [--cell-left:36.5] {{ tl }} size-3 2xl:block -translate-x-1/2 -translate-y-1/2" color="coral"></decor-diamond>
  <div class="hidden absolute size-(--cell-size) [--cell-top:1] [--cell-left:33] {{ tl }} 2xl:grid place-content-center"><div class="size-2 rounded-full bg-seabed-indigo"></div></div>
  <div class="hidden absolute size-(--cell-size) [--cell-top:4] [--cell-left:23] xl:[--cell-top:5] xl:[--cell-left:28] 2xl:[--cell-top:4] 2xl:[--cell-left:23] {{ tl }} lg:grid place-content-center"><div class="size-2 rounded-full bg-coral-red"></div></div>

  {{ svg("@webroot/dist/images/icon--eye-can-see-you.svg", true, true)|attr({ class: "hidden absolute [--cell-top:2] [--cell-left:17] lg:[--cell-left:22] xl:[--cell-top:3] xl:[--cell-left:27] 2xl:[--cell-top:4] 2xl:[--cell-left:32.5] " ~ tl ~ " w-12 -translate-x-1/2 -translate-y-1/2 md:block xl:w-14 2xl:w-16" }) }}
  <decor-star class="hidden text-seabed-indigo animate-spin-very-slow absolute [--cell-top:1] [--cell-left:21] 2xl:[--cell-top:2] 2xl:[--cell-left:27] {{ tl }} w-8 2xl:w-12 -translate-x-1/2 -translate-y-1/2 xl:block"></decor-star>
</div>
